# PostgreSQL (docker compose up -d postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/argos

# Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Grading LLM — o provider é escolhido pelo prefixo de GRADING_MODEL_ID:
#   gemini-*  -> Gemini    (usa GEMINI_API_KEY)
#   claude-*  -> Anthropic (usa ANTHROPIC_API_KEY)
# Padrão: gemini-2.5-pro. Alternativas: gemini-3.1-pro (raciocínio mais forte),
# gemini-2.5-flash / gemini-2.5-flash-lite (mais baratos), claude-sonnet-5.
GRADING_MODEL_ID=

# Gemini (grading) — chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude (grading — provider alternativo)
ANTHROPIC_API_KEY=

# Google Cloud Vision (OCR) — service-account JSON as a single line
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Cloudflare R2 (essay images, short-lived)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=argos-essays

# Asaas (payments) — sandbox key for dev
ASAAS_API_KEY=
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

APP_URL=http://localhost:3000

# Set to 1 to use in-memory fake vendor adapters (no external calls) — used by tests
FAKE_VENDORS=

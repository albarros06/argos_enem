# PostgreSQL (docker compose up -d postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/argos

# Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Grading LLM — o provider é escolhido pelo prefixo de GRADING_MODEL_ID:
#   gemini-*  -> Vertex AI (usa GOOGLE_APPLICATION_CREDENTIALS_JSON — service account)
#   claude-*  -> Anthropic (usa ANTHROPIC_API_KEY)
# Padrão: gemini-3.1-pro-preview. Reverter: GRADING_MODEL_ID=gemini-2.5-pro
# (2.5 é aposentado em 2026-10-16). Alternativas: gemini-2.5-flash (mais barato),
# claude-sonnet-5.
GRADING_MODEL_ID=
# Teto de tokens de saída do grading. Suba se modelos com "thinking" (Gemini 3)
# devolverem respostas vazias/truncadas.
GRADING_MAX_OUTPUT_TOKENS=

# OCR de imagens — IMAGE_OCR_MODEL_ID escolhe o motor:
#   gemini-*        -> transcrição por LLM no Vertex AI (ignora linhas/numeração
#                      impressas do papel; NÃO corrige os erros do aluno — C1)
#   google-vision   -> Google Vision (OCR pixel a pixel; reverter para cá)
# Padrão: gemini-3-flash-preview. PDFs continuam sempre no Vision (contagem de páginas).
IMAGE_OCR_MODEL_ID=
IMAGE_OCR_MAX_OUTPUT_TOKENS=

# Claude (grading — provider alternativo)
ANTHROPIC_API_KEY=

# Google Cloud service account (OCR + grading via Vertex AI) — JSON em uma única linha.
# A mesma credencial autentica o Vision (OCR) e o Vertex AI (grading Gemini); ela
# precisa do papel roles/aiplatform.user e da API aiplatform.googleapis.com habilitada.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Vertex AI (grading) — us-central1 serve o gemini-2.5-pro (indisponível em
# southamerica-east1). Processamento transitório nos EUA; ver spec FR-011.
GOOGLE_CLOUD_LOCATION=us-central1
# Opcional: só se o projeto do Vertex diferir do project_id da credencial.
GOOGLE_CLOUD_PROJECT=

# Cloudflare R2 (essay images, short-lived)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=argos-essays

# Asaas (payments) — sandbox key for dev
ASAAS_API_KEY=
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

APP_URL=http://localhost:3000

# Set to 1 to use in-memory fake vendor adapters (no external calls) — used by tests
FAKE_VENDORS=
